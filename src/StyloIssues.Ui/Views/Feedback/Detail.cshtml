@model IssueDetail
@{
    ViewData["Title"] = $"#{Model.Number} {Model.Title}";
}
<h1><a href="@Model.HtmlUrl" rel="noopener">#@Model.Number</a> @Model.Title</h1>
<p>State: @Model.State | Updated: @Model.UpdatedAt.ToString("yyyy-MM-dd")</p>

<div class="issue-body">
    @Html.Raw(System.Net.WebUtility.HtmlEncode(Model.Body).Replace("\n", "<br />"))
</div>

<hr />
<h2>Comments</h2>

@if (Model.Comments.Count == 0)
{
    <p>No comments yet.</p>
}
else
{
    foreach (var comment in Model.Comments)
    {
        <partial name="_Comment" model="comment" />
    }
}

<h3>Add a comment</h3>
<form method="post" action="/feedback/@Model.Number/comment"
      hx-post="/feedback/@Model.Number/comment" hx-target="body"
      x-data="{ body: '' }">
    <label for="comment-body">Comment</label>
    <textarea id="comment-body" name="body" x-model="body"
              required placeholder="Your comment"></textarea>
    <button type="submit" :disabled="!body">Post comment</button>
</form>
